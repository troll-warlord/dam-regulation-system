# =============================================================================
# Dam Regulation System — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Dam Regulation System"
APP_VERSION="0.1.0"
DEBUG=false

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# ---------------------------------------------------------------------------
# Database
# SQLite  (default, zero-config): sqlite:///./storage/drs.db
# PostgreSQL (future migration) : postgresql+asyncpg://user:pass@host/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./storage/drs.db

# ---------------------------------------------------------------------------
# ML Model Storage
# Directory where serialised scikit-learn models (.joblib) are persisted.
# ---------------------------------------------------------------------------
MODELS_DIR=./storage/models

# ---------------------------------------------------------------------------
# Forecasting Defaults
# ---------------------------------------------------------------------------
DEFAULT_FORECAST_DAYS=10
